<UserControl x:Class="mitoSoft.homeNet.ArduinoIDE.WPF.Views.MissingHomeNetElementsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:helpers="clr-namespace:mitoSoft.homeNet.ArduinoIDE.WPF.Helpers"
             xmlns:views="clr-namespace:mitoSoft.homeNet.ArduinoIDE.WPF.Views"
             xmlns:p="clr-namespace:mitoSoft.homeNet.ArduinoIDE.WPF.Properties">
    <DockPanel>
        <views:FindBarControl x:Name="FindBar" DockPanel.Dock="Top" Visibility="Visible"/>
        <Border DockPanel.Dock="Top"
                Background="#FFF0F4FF"
                BorderBrush="#FFAEC6E8"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <TextBlock TextWrapping="Wrap"
                       Foreground="#FF1E3A5F"
                       FontSize="12"><Run Text="{x:Static p:Resources.MissingElements_Description}"/><Run FontWeight="Bold" Text="{x:Static p:Resources.MissingElements_TextBold}"/><Run Text="{x:Static p:Resources.MissingElements_TextAfter}"/></TextBlock>
        </Border>
        <avalonedit:TextEditor x:Name="TextEditor"
                               IsReadOnly="True"
                               ShowLineNumbers="True"
                               VerticalScrollBarVisibility="Auto"
                               HorizontalScrollBarVisibility="Auto"
                               FontFamily="Consolas"
                               FontSize="11"
                               Background="White"
                               IsManipulationEnabled="True"
                               ScrollViewer.PanningMode="VerticalOnly"
                               ScrollViewer.PanningDeceleration="0.001"
                               ScrollViewer.PanningRatio="1.0"
                               helpers:SyntaxHighlightingHelper.HighlightingFile="/Editor/YAML.xshd"/>
    </DockPanel>
</UserControl>
