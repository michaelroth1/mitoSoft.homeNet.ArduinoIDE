<UserControl x:Class="mitoSoft.homeNet.ArduinoIDE.WPF.Views.YamlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:helpers="clr-namespace:mitoSoft.homeNet.ArduinoIDE.WPF.Helpers"
             xmlns:views="clr-namespace:mitoSoft.homeNet.ArduinoIDE.WPF.Views">
    <DockPanel>
        <views:FindBarControl x:Name="FindBar" DockPanel.Dock="Top" Visibility="Visible"/>
        <ToolBar DockPanel.Dock="Top">
            <Button Click="CommentButton_Click" Style="{StaticResource IconButtonStyle}" ToolTip="Comment selected lines">
                <Image Source="/Resources/CommentCode.png" Width="18" Height="18" RenderOptions.BitmapScalingMode="HighQuality"/>
            </Button>
            <Button Click="UncommentButton_Click" Style="{StaticResource IconButtonStyle}" ToolTip="Uncomment selected lines">
                <Image Source="/Resources/UncommentCode.png" Width="18" Height="18" RenderOptions.BitmapScalingMode="HighQuality"/>
            </Button>
            <Separator/>
            <Button Click="SelectHomeNetNodeButton_Click" Style="{StaticResource IconButtonStyle}" ToolTip="Select homeNet node">
                <TextBlock Text="homeNet:" FontFamily="Consolas" FontSize="11"/>
            </Button>
        </ToolBar>
        <avalonedit:TextEditor x:Name="YamlTextEditor"
                               ShowLineNumbers="True"
                               FontFamily="Consolas"
                               FontSize="12"
                               VerticalScrollBarVisibility="Auto"
                               HorizontalScrollBarVisibility="Auto"
                               IsManipulationEnabled="True"
                               ScrollViewer.PanningMode="VerticalOnly"
                               ScrollViewer.PanningDeceleration="0.001"
                               ScrollViewer.PanningRatio="1.0"
                               helpers:SyntaxHighlightingHelper.HighlightingFile="/Editor/YAML.xshd"/>
    </DockPanel>
</UserControl>
