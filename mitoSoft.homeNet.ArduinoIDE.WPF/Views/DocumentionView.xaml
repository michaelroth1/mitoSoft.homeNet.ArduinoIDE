<UserControl x:Class="mitoSoft.homeNet.ArduinoIDE.WPF.Views.DocumentionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <ToolBar DockPanel.Dock="Top">
            <Button x:Name="PrintButton" 
                    Content="Print / Export" 
                    Padding="10,2,10,2" 
                    Margin="0,0,5,0"
                    Click="PrintButton_Click"/>
            <Button x:Name="ClearHighlightsButton" 
                    Content="Clear Highlights" 
                    Padding="10,2,10,2"
                    Click="ClearHighlightsButton_Click"/>
        </ToolBar>

        <ScrollViewer x:Name="MainScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Background="White">
            <StackPanel x:Name="ContentPanel" Margin="10"/>
        </ScrollViewer>
    </DockPanel>
</UserControl>
