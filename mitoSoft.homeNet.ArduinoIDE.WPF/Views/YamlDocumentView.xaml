<UserControl x:Class="mitoSoft.homeNet.ArduinoIDE.WPF.Views.YamlDocumentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:helpers="clr-namespace:mitoSoft.homeNet.ArduinoIDE.WPF.Helpers">
    <avalonedit:TextEditor x:Name="YamlTextEditor"
                           ShowLineNumbers="True"
                           FontFamily="Consolas"
                           FontSize="12"
                           VerticalScrollBarVisibility="Auto"
                           HorizontalScrollBarVisibility="Auto"
                           IsManipulationEnabled="True"
                           helpers:SyntaxHighlightingHelper.HighlightingFile="/Editor/YAML.xshd"/>
</UserControl>
