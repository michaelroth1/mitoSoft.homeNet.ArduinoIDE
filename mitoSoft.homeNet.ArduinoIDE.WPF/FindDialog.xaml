<Window x:Class="mitoSoft.homeNet.ArduinoIDE.WPF.FindDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find" Height="150" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Find what:" VerticalAlignment="Center"/>
        <TextBox x:Name="SearchTextBox" 
                 Grid.Row="0" Grid.Column="1" 
                 Margin="5"
                 VerticalAlignment="Center"
                 KeyDown="SearchTextBox_KeyDown"/>

        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Find Next" 
                    Width="100" 
                    Margin="5,0"
                    IsDefault="True"
                    Click="FindButton_Click"/>
            <Button Content="Cancel" 
                    Width="100" 
                    Margin="5,0"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
