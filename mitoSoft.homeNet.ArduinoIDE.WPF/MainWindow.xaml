<Window x:Class="mitoSoft.homeNet.ArduinoIDE.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:xcad="http://schemas.xceed.com/wpf/xaml/avalondock"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:local="clr-namespace:mitoSoft.homeNet.ArduinoIDE.WPF"
        mc:Ignorable="d"
        Title="mitoSoft homeNet Arduino IDE" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Window.InputBindings>
        <KeyBinding Key="F" Modifiers="Control" Command="{Binding FindCommand}"/>
    </Window.InputBindings>
    <DockPanel>
        <!-- Menu -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open..." Click="OpenMenuItem_Click">
                    <MenuItem.Icon>
                        <Image Source="/Resources/OpenFile.png" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Save..." Click="SaveMenuItem_Click">
                    <MenuItem.Icon>
                        <Image Source="/Resources/Save.png" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="E_xit" Click="ExitMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Find..." Click="FindMenuItem_Click" InputGestureText="Ctrl+F"/>
                <Separator/>
                <MenuItem Header="Copy to _Clipboard" Click="CopyToClipboardMenuItem_Click" InputGestureText="Ctrl+C"/>
                <Separator/>
                <MenuItem Header="_Comment" Click="CommentMenuItem_Click">
                    <MenuItem.Icon>
                        <Image Source="/Resources/CommentCode.png" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Uncomment" Click="UncommentMenuItem_Click">
                    <MenuItem.Icon>
                        <Image Source="/Resources/UncommentCode.png" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Select homeNet Node" Click="SelectHomeNetNodeMenuItem_Click"/>
                <MenuItem Header="Create HomeNet Elements" Click="CreateHomeNetElementsMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Controllers" x:Name="ViewControllersMenuItem" IsCheckable="True" IsChecked="True" Click="ViewControllersMenuItem_Click"/>
                <MenuItem Header="_Errors / Warnings" x:Name="ViewErrorsMenuItem" IsCheckable="True" IsChecked="True" Click="ViewErrorsMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top">
            <Button Click="CheckButton_Click" Style="{StaticResource IconButtonStyle}" ToolTip="Check errors and warnings">
                <Image Source="/Resources/Check.png" Width="18" Height="18" RenderOptions.BitmapScalingMode="HighQuality"/>
            </Button>
            <Button Click="BuildButton_Click" Style="{StaticResource IconButtonStyle}" ToolTip="Build Arduino code">
                <Image Source="/Resources/Build.png" Width="18" Height="18" RenderOptions.BitmapScalingMode="HighQuality"/>
            </Button>
            <Separator/>
            <Button Click="CommentButton_Click" Style="{StaticResource IconButtonStyle}" ToolTip="Comment selected lines">
                <Image Source="/Resources/CommentCode.png" Width="18" Height="18" RenderOptions.BitmapScalingMode="HighQuality"/>
            </Button>
            <Button Click="UncommentButton_Click" Style="{StaticResource IconButtonStyle}" ToolTip="Uncomment selected lines">
                <Image Source="/Resources/UncommentCode.png" Width="18" Height="18" RenderOptions.BitmapScalingMode="HighQuality"/>
            </Button>
            <Button Click="CopyToClipboardMenuItem_Click" Style="{StaticResource IconButtonStyle}" ToolTip="Copy active panel content to clipboard">
                <Image Source="/Resources/Copy.png" Width="18" Height="18" RenderOptions.BitmapScalingMode="HighQuality"/>
            </Button>
            <Separator/>
            <Label Content="Zoom:" VerticalAlignment="Center"/>
            <Slider x:Name="ZoomSlider" Width="100" Minimum="0.5" Maximum="3" Value="1" 
                    VerticalAlignment="Center"
                    ValueChanged="ZoomSlider_ValueChanged" TickFrequency="0.1" IsSnapToTickEnabled="True"/>
        </ToolBar>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>

        <!-- AvalonDock DockingManager -->
        <xcad:DockingManager x:Name="DockingManager" AllowMixedOrientation="True">
            <xcad:LayoutRoot>
                <xcad:LayoutPanel Orientation="Vertical">
                    <xcad:LayoutPanel Orientation="Horizontal">
                        <!-- Left Side: Controller List -->
                        <xcad:LayoutAnchorablePaneGroup DockWidth="250">
                            <xcad:LayoutAnchorablePane>
                                <xcad:LayoutAnchorable Title="Controllers" x:Name="ControllersAnchorable" CanClose="True" CanHide="True" Hiding="LayoutAnchorable_Hiding">
                                    <DockPanel>
                                        <Label Content="Select Controller:" DockPanel.Dock="Top" Padding="5"/>
                                        <ListBox x:Name="ControllerListBox" 
                                                 SelectionChanged="ControllerListBox_SelectionChanged"
                                                 Margin="5"/>
                                    </DockPanel>
                                </xcad:LayoutAnchorable>
                            </xcad:LayoutAnchorablePane>
                        </xcad:LayoutAnchorablePaneGroup>

                        <!-- Center: Main Content -->
                        <xcad:LayoutDocumentPaneGroup>
                            <xcad:LayoutDocumentPane x:Name="DocumentPane">
                                <xcad:LayoutDocument Title="YAML Editor" CanClose="False">
                                    <avalonEdit:TextEditor x:Name="YamlTextBox" 
                                             ShowLineNumbers="True"
                                             FontFamily="Consolas"
                                             FontSize="12"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"/>
                                </xcad:LayoutDocument>
                            </xcad:LayoutDocumentPane>
                        </xcad:LayoutDocumentPaneGroup>
                    </xcad:LayoutPanel>

                    <!-- Bottom: Errors and Warnings -->
                    <xcad:LayoutAnchorablePaneGroup DockHeight="150">
                        <xcad:LayoutAnchorablePane>
                            <xcad:LayoutAnchorable Title="Errors / Warnings" x:Name="ErrorsAnchorable" CanClose="True" Hiding="LayoutAnchorable_Hiding">
                                <TextBox x:Name="ErrorTextBox" 
                                         IsReadOnly="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         Background="#FFF5F5F5"/>
                            </xcad:LayoutAnchorable>
                        </xcad:LayoutAnchorablePane>
                    </xcad:LayoutAnchorablePaneGroup>
                </xcad:LayoutPanel>
            </xcad:LayoutRoot>
        </xcad:DockingManager>
    </DockPanel>
</Window>
