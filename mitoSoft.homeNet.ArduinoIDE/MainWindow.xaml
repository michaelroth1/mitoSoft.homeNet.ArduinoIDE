<Window x:Class="mitoSoft.homeNet.ArduinoIDE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:xcad="http://schemas.xceed.com/wpf/xaml/avalondock"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:views="clr-namespace:mitoSoft.homeNet.ArduinoIDE.Views"
        xmlns:local="clr-namespace:mitoSoft.homeNet.ArduinoIDE"
        xmlns:p="clr-namespace:mitoSoft.homeNet.ArduinoIDE.Properties"
        mc:Ignorable="d"
        Title="homeNet IDE" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Window.InputBindings>
        <KeyBinding Key="F" Modifiers="Control" Command="{Binding FindCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}"/>
    </Window.InputBindings>
    <DockPanel>
        <!-- Menu -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="{x:Static p:Resources.Menu_File}">
                <MenuItem Header="{x:Static p:Resources.Menu_Open}" Click="OpenMenuItem_Click">
                    <MenuItem.Icon>
                        <Image Source="/Resources/OpenFile.png" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{x:Static p:Resources.Menu_Save}" Click="SaveMenuItem_Click" InputGestureText="Ctrl+S">
                    <MenuItem.Icon>
                        <Image Source="/Resources/Save.png" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{x:Static p:Resources.Menu_SaveAs}" Click="SaveAsMenuItem_Click">
                    <MenuItem.Icon>
                        <Image Source="/Resources/Save.png" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{x:Static p:Resources.Menu_Exit}" Click="ExitMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="{x:Static p:Resources.Menu_Edit}">
                <MenuItem Header="{x:Static p:Resources.Menu_Find}" Click="FindMenuItem_Click" InputGestureText="Ctrl+F">
                    <MenuItem.Icon>
                        <Image Source="/Resources/Magnifier.png" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{x:Static p:Resources.Menu_CopyToClipboard}" Click="CopyToClipboardMenuItem_Click" InputGestureText="Ctrl+C">
                    <MenuItem.Icon>
                        <Image Source="/Resources/Copy.png" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{x:Static p:Resources.Menu_MissingHomeNetElements}" Click="MissingHomeNetElementsMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="{x:Static p:Resources.Menu_GpioDocumentation}" Click="GpioDocumentationMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="{x:Static p:Resources.Menu_View}">
                <MenuItem Header="{x:Static p:Resources.Menu_Controllers}" x:Name="ViewControllersMenuItem" IsCheckable="True" IsChecked="True" Click="ViewControllersMenuItem_Click"/>
                <MenuItem Header="{x:Static p:Resources.Menu_ErrorsWarnings}" x:Name="ViewErrorsMenuItem" IsCheckable="True" IsChecked="True" Click="ViewErrorsMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top">
            <Button Click="CheckButton_Click" Style="{StaticResource IconButtonStyle}" ToolTip="{x:Static p:Resources.Tooltip_Check}">
                <Image Source="/Resources/Check.png" Width="18" Height="18" RenderOptions.BitmapScalingMode="HighQuality"/>
            </Button>
            <Button Click="BuildButton_Click" Style="{StaticResource IconButtonStyle}" ToolTip="{x:Static p:Resources.Tooltip_Build}">
                <Image Source="/Resources/Build.png" Width="18" Height="18" RenderOptions.BitmapScalingMode="HighQuality"/>
            </Button>
            <Separator/>
            <Button Click="CopyToClipboardMenuItem_Click" Style="{StaticResource IconButtonStyle}" ToolTip="{x:Static p:Resources.Tooltip_CopyToClipboard}">
                <Image Source="/Resources/Copy.png" Width="18" Height="18" RenderOptions.BitmapScalingMode="HighQuality"/>
            </Button>
            <Button Click="FindMenuItem_Click" Style="{StaticResource IconButtonStyle}" ToolTip="{x:Static p:Resources.Tooltip_Find}">
                <Image Source="/Resources/Magnifier.png" Width="18" Height="18" RenderOptions.BitmapScalingMode="HighQuality"/>
            </Button>
            <Separator/>
            <Label Content="{x:Static p:Resources.Label_Zoom}" VerticalAlignment="Center"/>
            <Slider x:Name="ZoomSlider" Width="100" Minimum="0.5" Maximum="3" Value="1" 
                    VerticalAlignment="Center"
                    ValueChanged="ZoomSlider_ValueChanged" TickFrequency="0.1" IsSnapToTickEnabled="True"/>
        </ToolBar>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="{x:Static p:Resources.Status_Ready}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- AvalonDock DockingManager -->
        <xcad:DockingManager x:Name="DockingManager" AllowMixedOrientation="True">
            <xcad:LayoutRoot>
                <xcad:LayoutPanel Orientation="Vertical">
                    <xcad:LayoutPanel Orientation="Horizontal">
                        <!-- Left Side: Controller List -->
                        <xcad:LayoutAnchorablePaneGroup DockWidth="250">
                            <xcad:LayoutAnchorablePane>
                                <xcad:LayoutAnchorable Title="{x:Static p:Resources.Title_Controllers}" x:Name="ControllersAnchorable" CanClose="True" CanHide="True" Hiding="LayoutAnchorable_Hiding">
                                    <DockPanel>
                                        <Label Content="{x:Static p:Resources.Label_SelectController}" DockPanel.Dock="Top" Padding="5"/>
                                        <ListBox x:Name="ControllerListBox" 
                                                 SelectionChanged="ControllerListBox_SelectionChanged"
                                                 Margin="5"/>
                                    </DockPanel>
                                </xcad:LayoutAnchorable>
                            </xcad:LayoutAnchorablePane>
                        </xcad:LayoutAnchorablePaneGroup>

                        <!-- Center: Main Content -->
                        <xcad:LayoutDocumentPaneGroup>
                            <xcad:LayoutDocumentPane x:Name="DocumentPane">
                                <xcad:LayoutDocument Title="{x:Static p:Resources.Title_YamlEditor}" CanClose="False">
                                    <views:YamlView x:Name="YamlView"/>
                                </xcad:LayoutDocument>
                            </xcad:LayoutDocumentPane>
                        </xcad:LayoutDocumentPaneGroup>
                    </xcad:LayoutPanel>

                    <!-- Bottom: Errors and Warnings -->
                    <xcad:LayoutAnchorablePaneGroup DockHeight="150">
                        <xcad:LayoutAnchorablePane>
                            <xcad:LayoutAnchorable Title="{x:Static p:Resources.Title_ErrorsWarnings}" x:Name="ErrorsAnchorable" CanClose="True" Hiding="LayoutAnchorable_Hiding">
                                <TextBox x:Name="ErrorTextBox" 
                                         IsReadOnly="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         Background="#FFF5F5F5"/>
                            </xcad:LayoutAnchorable>
                        </xcad:LayoutAnchorablePane>
                    </xcad:LayoutAnchorablePaneGroup>
                </xcad:LayoutPanel>
            </xcad:LayoutRoot>
        </xcad:DockingManager>
    </DockPanel>
</Window>